# --- Producción (VPS JobShours 64.23.199.180) ---
# API_UPSTREAM=http://127.0.0.1:8002
# FOTOS_UPSTREAM=http://127.0.0.1:8003
#
# --- Desarrollo local (wamp) ---
# API_UPSTREAM=http://localhost:8002
# FOTOS_UPSTREAM=http://localhost:8003
#
# --- Toppi's marketing (opcional) ---
# NEXT_PUBLIC_META_PIXEL_ID=          # mismo ID que META_PIXEL_ID en Laravel
# META_PIXEL_ID=
# MARKETING_WEEKLY_OFFER_ENABLED=true
# MARKETING_WEEKLY_OFFER_TITLE=Combo Toppi's exclusivo web
# MARKETING_WEEKLY_OFFER_HREF=/helados
# MARKETING_WEEKLY_OFFER_COUPON=MORALESWEB10
# NEXT_PUBLIC_TOPPIS_WHATSAPP_MESSAGE=Hola, quiero pedir Toppi's en Renaico
# NEXT_PUBLIC_TOPPIS_COUPON_DIRECT=WHATSAPP3000
