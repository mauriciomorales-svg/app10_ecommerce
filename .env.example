APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Multi-tienda (ver docs/COMMERCE_MULTI_STORE.md). Slug de la tienda cuando el Host no matchea primary_host ni host_aliases.
COMMERCE_DEFAULT_STORE_SLUG=default

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# --- PostgreSQL (DondeMorales + inventario-api en el mismo servidor / WAMP) ---
# Misma base `dbisabel2` en ambos proyectos si comparten catálogo (productos, categorías, etc.).
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=dbisabel2
# DB_USERNAME=postgres
# DB_PASSWORD=

# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Pagos web (dondemorales.cl) — modo seguro: Flow activo, MP online hasta configurar token
PAYMENTS_FLOW_ENABLED=true
PAYMENTS_MP_ONLINE_ENABLED=false

# Flow (producción)
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_SANDBOX=false

# Mercado Pago online (opcional; requiere PAYMENTS_MP_ONLINE_ENABLED=true)
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_WEBHOOK_SECRET=

# Retiro en tienda + empaque (checkout)
PACKAGING_PICKUP_ADDRESS="Santiago Watt 205, Renaico, Araucanía"
PACKAGING_PICKUP_HOURS="Lun-Dom 9:00-21:00"
PACKAGING_WHATSAPP=+56976647756
PACKAGING_FREE_REINFORCED_FROM=10000
PACKAGING_PRICE_STANDARD=290
PACKAGING_PRICE_REINFORCED=590
PACKAGING_PRICE_GIFT_BOX=1490

# Envío a domicilio (cotización por distancia desde la tienda)
DELIVERY_STORE_LAT=-37.6672
DELIVERY_STORE_LNG=-72.5730
DELIVERY_BASE_COMMUNE_CLP=2000
DELIVERY_INCLUDED_KM=3
DELIVERY_PER_EXTRA_KM_CLP=600
DELIVERY_MAX_RADIUS_KM=18
DELIVERY_GEOCODE_ENABLED=true

# JobsHours: publicar mandado en mapa tras pago con envío (token: php artisan store-demand:integration en jobshour-api)
# Tras pago de productos: publica mandado en mapa JobsHours (Bearer store-demand)
JOBSHOURS_WEB_URL=https://jobshours.com
# JOBSHOURS_DELIVERY_RETURN_URL=https://dondemorales.cl/pago/resultado
JOBSHOURS_MAX_PUBLISH_ATTEMPTS=12
JOBSHOURS_RETRY_HOURS=48
JOBSHOURS_STATUS_SYNC_DAYS=7
# WhatsApp Cloud API (opcional; si no, solo wa.me en resultado)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v18.0
# DELIVERY_ALERT_EMAIL=tienda@ejemplo.cl
JOBSHOURS_STORE_DEMAND_ENABLED=false
JOBSHOURS_API_URL=https://jobshours.com
# JOBSHOURS_STORE_DEMAND_TOKEN=jdh_...
# JOBSHOURS_STORE_DEMAND_CATEGORY_ID=

# Seguridad comercio (no requiere claves Flow/MP)
COMMERCE_LEGACY_POS_VENTAS_API=false
COMMERCE_TICKET_REQUIRE_SIGNATURE=true
